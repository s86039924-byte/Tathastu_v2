# Copy this to .env and fill in secrets
MONGO_URI=mongodb://127.0.0.1:27017/tathastu
PORT=4000
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
# true = fake Acadza DOST creation (no real API call); set false + ACADZA_BASE_URL for real
ACADZA_MOCK_MODE=true
# OpenAI key (used by config/openai.js) — keep this only in .env, never in code
OPENAI_API_KEY=your_openai_key_here
